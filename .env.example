# ===========================================================================
# 差旅 Agent 环境变量模板。
# 用法：cp .env.example .env，然后按需修改。.env 已被 .gitignore 忽略，绝不入库。
# 这一份同时被 docker-compose（POSTGRES_* 等）和后端 pydantic-settings 读取。
# ===========================================================================

# —— 应用 ——
APP_ENV=dev
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=true            # 本地想看人类可读日志可设 false

# —— Postgres ——
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=trip
POSTGRES_PASSWORD=trip_pass
POSTGRES_DB=trip_agent

# —— Redis ——
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# —— Qdrant ——
QDRANT_HOST=localhost
QDRANT_PORT=6333

# —— DeepSeek（M1 填）：去 https://platform.deepseek.com 申请 ——
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# —— 工具层（M2）：mock 工具模拟网络延迟(毫秒)。演示并发时设 300，平时留 0 ——
TOOL_MOCK_LATENCY_MS=0

# —— JWT（M3 用）：生产务必换成强随机串，例如 `openssl rand -hex 32` ——
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
